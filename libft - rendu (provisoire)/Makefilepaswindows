NAME = libft.a
CC = gcc
CFLAGS = -Werror -Wextra -Wall

SRCS_LIBC = $(wildcard ft\ libc/*.c)
SRCS_SUPP = $(wildcard ft\ supp/*.c)
SRCS_BONUS = $(wildcard ft\ bonus/*.c)

OBJS_LIBC = $(SRCS_LIBC:.c=.o)
OBJS_SUPP = $(SRCS_SUPP:.c=.o)
OBJS_BONUS = $(SRCS_BONUS:.c=.o)

all: $(NAME)

$(NAME): $(OBJS_LIBC) $(OBJS_SUPP)
	ar rcs $(NAME) $(OBJS_LIBC) $(OBJS_SUPP)

bonus: $(OBJS_LIBC) $(OBJS_SUPP) $(OBJS_BONUS)
	ar rcs $(NAME) $(OBJS_LIBC) $(OBJS_SUPP) $(OBJS_BONUS)

clean:
	rm -f $(OBJS_LIBC) $(OBJS_SUPP) $(OBJS_BONUS)

fclean: clean
	rm -f $(NAME)

re: fclean all

.PHONY: all bonus clean fclean re